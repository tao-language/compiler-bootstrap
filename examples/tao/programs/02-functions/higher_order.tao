// Higher-order functions: functions that take functions as arguments
// Expected output: 30

fn apply(f: fn(I32) -> I32, x: I32) -> I32 {
  f(x)
}

fn double(x: I32) -> I32 {
  x * 2
}

fn add_ten(x: I32) -> I32 {
  x + 10
}

// apply(double, 10) = 20
// apply(add_ten, 20) = 30
apply(add_ten, apply(double, 10))
