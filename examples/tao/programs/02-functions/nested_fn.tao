// Nested function calls
// Expected output: 15
// Note: Nested calls require extra parentheses due to grammar limitations

fn double(x: I32) -> I32 {
  x * 2
}

fn add_one(x: I32) -> I32 {
  x + 1
}

// Composition: double(add_one(7)) = double(8) = 16
// Wait, let me recalculate: add_one(7) = 8, double(8) = 16
// Let me use different values for 15

fn triple(x: I32) -> I32 {
  x * 3
}

// Nested calls require extra parens: triple((add_one(4)))
triple((add_one(4)))
