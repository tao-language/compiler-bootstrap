// For loop: collection iteration
// Note: for loop syntax not yet implemented, using recursive function instead
// Expected output: 15 (sum of 1+2+3+4+5)

fn sum_list(numbers: List(I32)) -> I32 {
  match numbers {
    | [] -> 0
    | [n, ..rest] -> n + sum_list(rest)
  }
}
sum_list([1, 2, 3, 4, 5])
