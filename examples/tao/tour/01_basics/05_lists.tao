// Lists are immutable ordered collections of the same type.

// They are written using square brackets.
let empty = []
let primes = [2, 3, 5, 7, 11]

// Lists are immutable, transformations create new lists.
> primes.push(13)
[2, 3, 5, 7, 11, 13]

> primes + [13, 17]
[2, 3, 5, 7, 11, 13, 17]

// The original list has not changed.
> primes
[2, 3, 5, 7, 11]
