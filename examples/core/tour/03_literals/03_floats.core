%let float: %Float = 1.1; // floating point literal type

%let float16: %F16 = 1.1; // float 16 bits
%let float32: %F32 = 1.1; // float 32 bits
%let float64: %F64 = 1.1; // float 64 bits

// Float types can also accept integer literals, but not the other way around.
%let float_int_lit: %Float = 42;

float_int_lit  // evaluates to 42.0 — proves float accepts int literals
