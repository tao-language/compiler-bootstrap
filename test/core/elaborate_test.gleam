pub fn infer_err_test() {
  let term = ast.err(s)
  let ctx0 = new_ctx
  let #(result, type_, ctx) = infer(ctx0, term)
  assert ctx.errors == []
  assert result == tm.Err
  assert type_ == v.Err
}
