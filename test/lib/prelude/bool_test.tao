// Test file for Bool module
// Tests are in REPL format: > expression\nexpected_result

import prelude/bool.{not, and, or, xor, implies}

// not tests
> not(True)
False

> not(False)
True

// and tests
> and(True, True)
True

> and(True, False)
False

> and(False, True)
False

> and(False, False)
False

// or tests
> or(True, True)
True

> or(True, False)
True

> or(False, True)
True

> or(False, False)
False

// Complex expressions
> and(or(True, False), not(False))
True

> or(and(True, False), not(False))
True

> not(not(True))
True

> not(not(not(False)))
True

// Nested operations
> and(and(True, True), True)
True

> or(or(False, False), False)
False
